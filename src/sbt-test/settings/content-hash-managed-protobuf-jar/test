# Tests PB.cacheStyle := PB.CacheStyle.ContentHash for protobuf dependency jars on managedClasspath.
# The main source imports dep/dep.proto from the unpacked managed dependency, so this is also
# an end-to-end import-from-unpacked-dependency scenario.

> writeDepJar v1
> protocGenerate
> assertProtocCount 1
> assertExtractedDepIsV1
> assertFooReferencesDep

> protocGenerate
> assertProtocCount 1

$ touch deps/dep.jar
> protocGenerate
> assertProtocCount 1
> assertExtractedDepIsV1

> writeDepJar v2
> protocGenerate
> assertProtocCount 2
> assertExtractedDepIsV2
> assertFooReferencesDep

> protocGenerate
> assertProtocCount 2

$ touch deps/dep.jar
> protocGenerate
> assertProtocCount 2
> assertExtractedDepIsV2
